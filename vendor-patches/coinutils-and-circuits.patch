+        let env = Env::default();
+        env.cost_estimate().budget().reset_unlimited();
+
+        let coin = self.file_manager.read_coin_file(&coin_file)?;
+        let state = self.file_manager.read_state_file(&state_file)?;
+        // Read association set file if provided (mirrors handle_withdraw).
+        let association_set_data = if let Some(assoc_file) = association_file {
+            Some(self.file_manager.read_association_file(&assoc_file)?)
+        } else {
+            None
+        };
+        let manager = crate::merkle::transfer::TransferManager::new();
+        let (witness, new_coin) =
+            manager.build_transfer(&env, &coin.coin, &state, &fee, out_scope.as_bytes(), association_set_data.as_ref())?;
+
+        std::fs::write(&output, serde_json::to_string_pretty(&witness).map_err(crate::error::CoinUtilsError::Json)?)?;
+        self.file_manager.write_coin_file(&new_coin, &out_coin)?;
+
+        println!("Transfer witness:");
+        println!("  Fee: {}", witness.fee_public);
+        println!("  Output value: {}", witness.out_value);
+        println!("  Output commitment: {}", new_coin.commitment_hex);
+        println!("  Witness saved to: {}", output);
+        println!("  Output coin saved to: {}", out_coin);
+        Ok(())
+    }
