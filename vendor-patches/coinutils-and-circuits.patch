+    /// Generic Merkle inclusion proof for `leaf_index` in a depth-`depth` LeanIMT
+    /// built over the state file's `commitments`. Prints {root, leafIndex,
+    /// siblings} as JSON (decimal field elements). Enables compliance
+    /// allow/deny-adjacency witnesses.
+    pub fn handle_merkle_proof(&self, state_file: String, leaf_index: u32, depth: u32) -> Result<()> {
+        use crate::crypto::conversions::{bls_scalar_to_decimal_string, decimal_string_to_bls_scalar};
+        use lean_imt::{LeanIMT, bls_scalar_to_bytes};
+        let env = Env::default();
+        env.cost_estimate().budget().reset_unlimited();
+        let state_data = self.file_manager.read_state_file(&state_file)?;
+        let mut tree = LeanIMT::new(&env, depth);
+        for c in state_data.commitments.iter() {
+            let fr = decimal_string_to_bls_scalar(&env, c)?;
+            tree.insert(bls_scalar_to_bytes(fr))?;
+        }
+        let (siblings, _d) = tree
+            .generate_proof(leaf_index)
+            .ok_or(crate::error::CoinUtilsError::ProofGenerationFailed)?;
+        let siblings_dec: Vec<String> = siblings.iter().map(|s| bls_scalar_to_decimal_string(&s)).collect();
+        let root = bls_scalar_to_decimal_string(&lean_imt::bytes_to_bls_scalar(&tree.get_root()));
+        let json = serde_json::json!({ "root": root, "leafIndex": leaf_index, "siblings": siblings_dec });
+        println!("{}", serde_json::to_string(&json).map_err(crate::error::CoinUtilsError::Json)?);
+        Ok(())
+    }
+
+    /// Handle the transfer command (hidden-amount PrivateTransfer witness)
+    #[allow(clippy::too_many_arguments)]
