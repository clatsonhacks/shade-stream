+    pub fn handle_compute_root(&self, state_file: String) -> Result<()> {
+        let env = Env::default();
+        env.cost_estimate().budget().reset_unlimited();
+        let state_data = self.file_manager.read_state_file(&state_file)?;
+        let root = self.withdrawal_manager.compute_root(&env, &state_data)?;
