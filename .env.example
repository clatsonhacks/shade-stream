NODE_ENV=testnet

# User-provided wallet
ARB_SEPOLIA_PRIVATE_KEY=
# Optional alias accepted by setup:testnet when ARB_SEPOLIA_PRIVATE_KEY is omitted.
ETH_PRIVATE_KEY=
ARB_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
ARB_SEPOLIA_CHAIN_ID=421614
ARB_SEPOLIA_USDC_ADDRESS=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d
ARB_SEPOLIA_CCTP_TOKEN_MESSENGER=0x8FE6B999Dc680CcFDD5Bf7EB0974218be2542DAA
ARB_SEPOLIA_CCTP_MESSAGE_TRANSMITTER=0xE737e5cEBEEBa77EFE34D4aa090756590b1CE275
ARB_SEPOLIA_CCTP_DOMAIN=3

# Circle / CCTP
CCTP_ATTESTATION_API_BASE=https://iris-api-sandbox.circle.com
CCTP_VERSION=v2
STELLAR_CCTP_DOMAIN=27
STELLAR_CCTP_FORWARDER_CONTRACT=
STELLAR_CCTP_MESSAGE_TRANSMITTER_CONTRACT=
STELLAR_TESTNET_USDC_ASSET_CODE=USDC
STELLAR_TESTNET_USDC_ISSUER=
STELLAR_TESTNET_USDC_SAC_CONTRACT=

# Stellar
STELLAR_NETWORK=testnet
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_DEPLOYER_SECRET=
STELLAR_DEPLOYER_PUBLIC=
STELLAR_USER_SECRET=
STELLAR_USER_PUBLIC=
STELLAR_RELAYER_SECRET=
STELLAR_RELAYER_PUBLIC=
STELLAR_SOLVER_SECRET=
STELLAR_SOLVER_PUBLIC=

# Generated EVM solver wallet for RFQ cross-chain/proof-of-fill tests
ARB_SOLVER_PRIVATE_KEY=
ARB_SOLVER_ADDRESS=

# --- Canonical contracts (the ACTIVE settlement path) ---
# Deployed by: npm run contracts:deploy:pool (after contracts:build + circuits:build).
SHIELDED_POOL_CONTRACT=                  # canonical ShadePool (a.k.a. ShadeVaultV2)
NULLIFIER_REGISTRY_CONTRACT=             # authorized-spender-gated nullifier store
VERIFIER_WITHDRAW_CONTRACT=              # withdraw/rfq/cctp shared verifier (17-signal vk)
TRANSFER_VERIFIER_CONTRACT=              # private_transfer verifier (6-signal vk)
VERIFIER_DEPOSIT_NOTE_MINT_CONTRACT=     # deposit_note_mint verifier (14-signal vk)
STELLAR_CCTP_TOKEN_MESSENGER_MINTER=CDNG7HXAPBWICI2E3AUBP3YZWZELJLYSB6F5CC7WLDTLTHVM74SLRTHP
# Pool domain separators (must match coinutils config.rs POOL_ID/CHAIN_ID).
SHADE_POOL_ID=1
SHADE_CHAIN_ID=148

# --- Legacy contracts (DEPRECATED, not on the active path; see P1.1) ---
# Kept only for historical reference. Do not wire new flows to these.
SHADE_VAULT_CONTRACT=
COMMITMENT_TREE_CONTRACT=
COMPLIANCE_REGISTRY_CONTRACT=
INTENT_ESCROW_CONTRACT=
GOVERNANCE_GUARDIAN_CONTRACT=
VERIFIER_DEPOSIT_CONTRACT=
VERIFIER_RFQ_CONTRACT=
VERIFIER_FILL_CLAIM_CONTRACT=

# Backend
DATABASE_URL=postgres://shade:shade@localhost:5432/shade
REDIS_URL=redis://localhost:6379
API_PORT=8080
SOLVER_PORT=8081
RELAYER_PORT=8082
PROVER_PORT=8083

# Security
ENCRYPTION_MASTER_KEY=
INTENT_ENCRYPTION_PUBLIC_KEY=
INTENT_ENCRYPTION_PRIVATE_KEY=
SOLVER_SIGNING_PRIVATE_KEY=
SOLVER_SIGNING_PUBLIC_KEY=

# MPC committee — required when apps/mpc-committee persists node keys to
# DATABASE_URL. Encrypts committee secret keys at rest (AES-256-GCM); keep
# this OUT of the database and out of source control. Generate with:
#   openssl rand -hex 32
MPC_KEY_ENCRYPTION_SECRET=

# MPC independent-operator deployment (P4 #24) — node-server.ts /
# coordinator-server.ts, as opposed to the combined server.ts dev mode.
# Each of the 3 node operators sets MPC_NODE_ID to their own value
# (node-1/node-2/node-3) and runs their own DATABASE_URL + MPC_KEY_ENCRYPTION_SECRET.
# MPC_INTERNAL_TOKEN must be the SAME shared secret on the coordinator and
# every node (authenticates the coordinator to each node's HTTP API — an
# interim scheme; production should use mTLS instead). Generate with:
#   openssl rand -hex 32
MPC_INTERNAL_TOKEN=
MPC_NODE_ID=
MPC_NODE_PORT=8091
# Coordinator-only: nodeId=url pairs, comma-separated.
MPC_NODE_URLS=node-1=http://localhost:8091,node-2=http://localhost:8092,node-3=http://localhost:8093

# Shade View — signs selective-disclosure reports (POST /v1/reports/view-key).
# A Stellar secret key (S...); the service's Ed25519 pubkey is derived from it
# and returned in every report so a bank/auditor can verify authenticity.
SHADE_VIEW_SIGNING_SECRET=

# Proofs
PROOF_SYSTEM=
PROVING_KEY_PATH=
VERIFYING_KEY_PATH=
CIRCUIT_BUILD_DIR=
