{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@shade/shared-types": ["packages/shared-types/src/index.ts"],
      "@shade/cctp-utils": ["packages/cctp-utils/src/index.ts"],
      "@shade/stellar-utils": ["packages/stellar-utils/src/index.ts"],
      "@shade/evm-utils": ["packages/evm-utils/src/index.ts"],
      "@shade/note-crypto": ["packages/note-crypto/src/index.ts"],
      "@shade/proof-utils": ["packages/proof-utils/src/index.ts"],
      "@shade/rfq-types": ["packages/rfq-types/src/index.ts"],
      "@shade/queue": ["packages/queue/src/index.ts"],
      "@shade/note-vault": ["packages/note-vault/src/index.ts"],
      "@shade/auth-privy": ["packages/auth-privy/src/index.ts"],
      "@shade/stellar-actions": ["packages/stellar-actions/src/index.ts"],
      "@shade/proving": ["packages/proving/src/index.ts"],
      "@shade/proving/paths": ["packages/proving/src/paths.ts"],
      "@shade/proving/env": ["packages/proving/src/env.ts"],
      "@shade/cctp": ["packages/cctp/src/index.ts"],
      "@shade/rfq": ["packages/rfq/src/index.ts"],
      "@shade/mpc-crypto": ["packages/mpc-crypto/src/index.ts"],
      "@shade/assets": ["packages/assets/src/index.ts"]
    }
  },
  "include": ["apps/**/*.ts", "packages/**/*.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules", "apps/web"]
}
